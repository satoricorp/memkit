# Convex Deployment
# Get this from https://dashboard.convex.dev after creating a project
# Run `npx convex dev` to set up your deployment
CONVEX_DEPLOYMENT=dev:sincere-ladybug-857
NEXT_PUBLIC_CONVEX_URL=https://sincere-ladybug-857.convex.cloud

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI Chat API (optional)
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.4

# Polar (optional)
POLAR_ACCESS_TOKEN=
POLAR_SANDBOX_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_SANDBOX_PRODUCT_ID=
SUCCESS_URL=http://localhost:3000

# Resend (optional)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
WELCOME_FROM="Brand <welcome@yourcompany.com>"

# Convex Auth (OAuth is configured via Convex env vars)
# Set in Convex Dashboard or via `npx convex env set`
# Required Convex env vars: SITE_URL, AUTH_GITHUB_ID, AUTH_GITHUB_SECRET,
# AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET, JWT_PRIVATE_KEY, JWKS
